# Popara — Environment Variables
# Copy this file to .env.local and replace placeholder values.
# See docs/standards/env-strategy.md for the full environment variable policy.
#
# Legend:
#   # required  — the app will not start without this variable
#   # optional  — falls back to the default shown if not set

# ---------------------------------------------------------------------------
# Shared / cross-workspace
# Variables used by more than one workspace are exempt from the scope-prefix
# rule (see docs/standards/env-strategy.md#naming-conventions).
# ---------------------------------------------------------------------------

# Application environment label (local | staging | production). # optional
APP_ENV=local

# ---------------------------------------------------------------------------
# apps/web — Next.js
#
# Public variables (NEXT_PUBLIC_*) are bundled into the browser and visible
# to end-users. Server-only variables must NOT carry the NEXT_PUBLIC_ prefix.
# ---------------------------------------------------------------------------

# Base URL of the backend API, consumed by client-side fetch calls. # required
NEXT_PUBLIC_API_URL=http://localhost:4000

# Full connection string for the primary database. # required
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/popara_dev

# Secret used to sign and verify session/JWT tokens. # required
# Generate one with: openssl rand -hex 32
AUTH_SECRET=change_me

# Sentry DSN for server-side error tracking. # optional
# SENTRY_DSN=

# SMTP settings for transactional email. # optional
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# ---------------------------------------------------------------------------
# apps/mobile — Expo / React Native
#
# Only EXPO_PUBLIC_* variables are bundled into the app binary. Do NOT add
# secrets here — there is no server boundary in the mobile app.
# ---------------------------------------------------------------------------

# Base URL of the backend API. # required
EXPO_PUBLIC_API_URL=http://localhost:4000

# Human-readable app name (overrides app.json displayName if set). # optional
EXPO_PUBLIC_APP_NAME=Popara

# ---------------------------------------------------------------------------
# apps/api — Node / API service
# Add variables here when the API workspace is implemented.
# ---------------------------------------------------------------------------
