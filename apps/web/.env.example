# Web app environment variables
# Copy this file to .env.local and replace placeholder values.
# See docs/standards/env-strategy.md for the full environment variable policy.
#
# Legend:
#   # required  — the app will not start without this variable
#   # optional  — falls back to the default shown if not set

# ---------------------------------------------------------------------------
# Public (client-safe) variables
# Prefix: NEXT_PUBLIC_
# These are bundled into the browser bundle and visible to end-users.
# ---------------------------------------------------------------------------

# Base URL of the backend API, consumed by client-side fetch calls. # required
NEXT_PUBLIC_API_URL=http://localhost:4000

# Application environment label shown in the UI (local | staging | production). # optional
NEXT_PUBLIC_APP_ENV=local

# ---------------------------------------------------------------------------
# Server-only variables
# No NEXT_PUBLIC_ prefix — available only in Server Components, Route Handlers,
# and server-side rendering. Never pass these to client components.
# ---------------------------------------------------------------------------

# Full connection string for the primary database. # required
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/popara_dev

# Secret used to sign and verify session/JWT tokens. # required
# Use a long random string, e.g.: openssl rand -hex 32
AUTH_SECRET=change_me

# ---------------------------------------------------------------------------
# Optional integrations (leave blank to disable)
# ---------------------------------------------------------------------------

# Sentry DSN for error tracking (server-side). # optional
# SENTRY_DSN=

# SMTP host for transactional email. # optional
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
